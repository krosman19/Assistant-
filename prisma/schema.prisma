generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }
enum Provider { gmail microsoft imap caldav icloud manual }
enum SourceType { email calendar manual inferred }
model User { id String @id @default(cuid()) email String @unique name String? timezone String @default("America/New_York") briefing_time String @default("07:00") briefing_length Int @default(5) tone String @default("executive") preferences Json @default("{}") created_at DateTime @default(now()) accounts ConnectedAccount[] emails EmailMessage[] events CalendarEvent[] topics InterestTopic[] briefings Briefing[] actions ActionItem[] }
model ConnectedAccount { id String @id @default(cuid()) user_id String provider Provider display_name String encrypted_credentials String scopes Json @default("[]") status String @default("connected") last_sync_at DateTime? created_at DateTime @default(now()) user User @relation(fields:[user_id], references:[id]) emails EmailMessage[] events CalendarEvent[] }
model EmailMessage { id String @id @default(cuid()) user_id String account_id String provider_message_id String thread_id String? from String to Json cc Json? subject String snippet String body_text String? received_at DateTime labels Json @default("[]") has_attachments Boolean @default(false) importance_score Int @default(0) importance_reason String? requires_action Boolean @default(false) action_deadline DateTime? created_at DateTime @default(now()) user User @relation(fields:[user_id], references:[id]) account ConnectedAccount @relation(fields:[account_id], references:[id]) }
model CalendarEvent { id String @id @default(cuid()) user_id String account_id String provider_event_id String title String start_time DateTime end_time DateTime location String? attendees Json @default("[]") description String? meeting_url String? source_calendar String importance_score Int @default(0) prep_notes String? created_at DateTime @default(now()) user User @relation(fields:[user_id], references:[id]) account ConnectedAccount @relation(fields:[account_id], references:[id]) }
model InterestTopic { id String @id @default(cuid()) user_id String topic String keywords Json @default("[]") sources Json @default("[]") priority Int @default(3) created_at DateTime @default(now()) user User @relation(fields:[user_id], references:[id]) }
model Briefing { id String @id @default(cuid()) user_id String briefing_date DateTime status String @default("ready") title String transcript String audio_url String? duration_seconds Int @default(0) summary_json Json action_items_json Json citations_json Json created_at DateTime @default(now()) user User @relation(fields:[user_id], references:[id]) }
model ActionItem { id String @id @default(cuid()) user_id String source_type SourceType source_id String? description String owner String? deadline DateTime? priority String @default("medium") status String @default("open") created_at DateTime @default(now()) user User @relation(fields:[user_id], references:[id]) }
